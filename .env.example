# UGENT LINE Proxy Configuration
# Copy this file to /etc/ugent-line-proxy/.env or ~/.ugent-line-proxy/.env

# =============================================================================
# Server Configuration
# =============================================================================

# Server bind address (default: 0.0.0.0:3000)
LINE_PROXY_BIND_ADDR=0.0.0.0:3000

# Server name for logging (optional)
LINE_PROXY_NAME=ugent-line-proxy

# =============================================================================
# LINE Configuration
# =============================================================================

# LINE Channel Secret (from LINE Developers Console)
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE Channel Access Token (from LINE Developers Console)
LINE_CHANNEL_ACCESS_TOKEN=your_access_token_here

# LINE webhook path (default: /line/callback)
LINE_PROXY_WEBHOOK_PATH=/line/callback

# Skip signature verification (ONLY for testing!)
LINE_PROXY_SKIP_SIGNATURE=false

# Process redelivered webhook events (default: true)
LINE_PROXY_PROCESS_REDELIVERIES=true

# =============================================================================
# WebSocket Configuration
# =============================================================================

# WebSocket path (default: /ws)
LINE_PROXY_WS_PATH=/ws

# WebSocket API key for authentication (optional but recommended)
LINE_PROXY_API_KEY=your_api_key_here

# WebSocket timeout in seconds (default: 60)
LINE_PROXY_WS_TIMEOUT=60

# WebSocket ping interval in seconds (default: 30)
LINE_PROXY_WS_PING_INTERVAL=30

# Maximum WebSocket message size in bytes (default: 10485760 = 10MB)
LINE_PROXY_WS_MAX_MESSAGE_SIZE=10485760

# =============================================================================
# Media Configuration
# =============================================================================

# Media cache directory (default: temp dir)
# LINE_PROXY_MEDIA_CACHE_DIR=/var/lib/ugent-line-proxy/cache

# Maximum cache size in MB (default: 500)
# LINE_PROXY_MEDIA_CACHE_MAX_MB=500

# Cache TTL in seconds (default: 3600)
# LINE_PROXY_MEDIA_CACHE_TTL=3600

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: trace, debug, info, warn, error (default: info)
LINE_PROXY_LOG_LEVEL=info

# Log format: json, pretty (default: json)
LINE_PROXY_LOG_FORMAT=json

# =============================================================================
# TLS Configuration (Optional)
# =============================================================================

# Path to TLS certificate file (enables HTTPS if set)
# LINE_PROXY_TLS_CERT=/path/to/cert.pem

# Path to TLS private key file
# LINE_PROXY_TLS_KEY=/path/to/key.pem
