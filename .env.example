# UGENT LINE Proxy Configuration
# Copy this file to /etc/ugent-line-proxy/.env or ~/.ugent-line-proxy/.env

# =============================================================================
# Server Configuration
# =============================================================================

# Server bind address (default: 0.0.0.0:3000)
BIND_ADDR=0.0.0.0:3000

# =============================================================================
# LINE Configuration
# =============================================================================

# LINE Channel Secret (from LINE Developers Console)
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE Channel Access Token (from LINE Developers Console)
LINE_CHANNEL_ACCESS_TOKEN=your_access_token_here

# LINE webhook path (default: /line/callback)
LINE_WEBHOOK_PATH=/line/callback

# Skip signature verification (ONLY for testing!)
LINE_SKIP_SIGNATURE=false

# Process redelivered webhook events
LINE_PROCESS_REDELIVERIES=false

# =============================================================================
# WebSocket Configuration
# =============================================================================

# WebSocket path (default: /ws)
WS_PATH=/ws

# WebSocket API key for authentication (optional)
WS_API_KEY=

# WebSocket timeout in seconds (default: 300)
WS_TIMEOUT_SECS=300

# WebSocket ping interval in seconds (default: 30)
WS_PING_INTERVAL_SECS=30

# Maximum WebSocket message size in bytes (default: 10485760 = 10MB)
WS_MAX_MESSAGE_SIZE=10485760

# =============================================================================
# Media Configuration
# =============================================================================

# Maximum media file size in bytes (default: 52428800 = 50MB)
MEDIA_MAX_SIZE=52428800

# Allowed media types (comma-separated)
MEDIA_ALLOWED_TYPES=image/jpeg,image/png,audio/m4a,video/mp4,application/pdf

# Media storage path (default: /var/lib/ugent-line-proxy/media)
MEDIA_STORAGE_PATH=/var/lib/ugent-line-proxy/media

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Log format: text, json (default: text)
LOG_FORMAT=text
