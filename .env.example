# UGENT LINE Proxy Configuration
# Copy this file to /etc/ugent-line-proxy/.env or ~/.ugent-line-proxy/.env

# =============================================================================
# Server Configuration
# =============================================================================

# Server bind address (default: 0.0.0.0:3000)
LINE_PROXY_BIND_ADDR=0.0.0.0:3000

# Server name for logging (optional)
LINE_PROXY_NAME=ugent-line-proxy

# =============================================================================
# LINE Configuration
# =============================================================================

# LINE Channel Secret (from LINE Developers Console)
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE Channel Access Token (from LINE Developers Console)
LINE_CHANNEL_ACCESS_TOKEN=your_access_token_here

# LINE webhook path (default: /line/callback)
LINE_PROXY_WEBHOOK_PATH=/line/callback

# Skip signature verification (ONLY for testing!)
LINE_PROXY_SKIP_SIGNATURE=false

# Process redelivered webhook events (default: true)
LINE_PROXY_PROCESS_REDELIVERIES=true

# Auto-show loading indicator when processing messages (default: true)
LINE_AUTO_LOADING_INDICATOR=true

# Auto-mark messages as read after processing (default: true)
LINE_AUTO_MARK_AS_READ=true

# =============================================================================
# WebSocket Configuration
# =============================================================================

# WebSocket path (default: /ws)
LINE_PROXY_WS_PATH=/ws

# WebSocket API key for authentication (optional but recommended)
LINE_PROXY_API_KEY=your_api_key_here

# WebSocket timeout in seconds (default: 60)
LINE_PROXY_WS_TIMEOUT=60

# WebSocket ping interval in seconds (default: 30)
LINE_PROXY_WS_PING_INTERVAL=30

# Maximum WebSocket message size in bytes (default: 10485760 = 10MB)
LINE_PROXY_WS_MAX_MESSAGE_SIZE=10485760

# =============================================================================
# Database Configuration
# =============================================================================

# Enable persistent storage (default: false)
LINE_PROXY_STORAGE_ENABLED=false

# Database type: sqlite or postgres (default: sqlite)
# Postgres requires building with --features postgres
LINE_PROXY_DB_TYPE=sqlite

# SQLite database path (default: ~/.ugent/line-plugin/line-proxy.db)
# LINE_PROXY_STORAGE_PATH=/var/lib/ugent-line-proxy/line-proxy.db

# PostgreSQL connection URL (required when db_type = postgres)
# LINE_PROXY_DB_URL=postgresql://user:password@localhost:5432/ugent_line

# =============================================================================
# Data Retention Configuration
# =============================================================================

# Enable automatic data retention cleanup (default: false)
# Requires LINE_PROXY_STORAGE_ENABLED=true
LINE_PROXY_RETENTION_ENABLED=false

# Retain contacts during cleanup (default: true)
LINE_PROXY_RETENTION_CONTACTS=true

# Retain messages during cleanup (default: true)
LINE_PROXY_RETENTION_MESSAGES=true

# Retain group membership during cleanup (default: true)
LINE_PROXY_RETENTION_GROUPS=true

# =============================================================================
# Retry Configuration
# =============================================================================

# Enable message delivery retry (default: true)
LINE_PROXY_RETRY_ENABLED=true

# Maximum retry attempts (default: 5)
LINE_PROXY_RETRY_MAX_ATTEMPTS=5

# Initial retry delay in milliseconds (default: 1000)
LINE_PROXY_RETRY_INITIAL_DELAY_MS=1000

# Maximum retry delay in milliseconds (default: 60000)
LINE_PROXY_RETRY_MAX_DELAY_MS=60000

# Inbound queue TTL in seconds - undelivered messages expire after this (default: 3600)
LINE_PROXY_INBOUND_QUEUE_TTL_SECS=3600

# =============================================================================
# Media Configuration
# =============================================================================

# Media cache directory (default: OS temp dir / ugent-line-proxy-cache)
# LINE_PROXY_MEDIA_CACHE_DIR=/var/lib/ugent-line-proxy/cache

# Maximum cache size in MB (default: 500)
# LINE_PROXY_MEDIA_CACHE_MAX_MB=500

# Cache TTL in seconds (default: 3600)
# LINE_PROXY_MEDIA_CACHE_TTL=3600

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: trace, debug, info, warn, error (default: info)
LINE_PROXY_LOG_LEVEL=info

# Log format: json, pretty (default: json)
LINE_PROXY_LOG_FORMAT=json

# Log file path (optional, logs to stdout if not set)
# LINE_PROXY_LOG_FILE=/var/log/ugent-line-proxy/proxy.log

# =============================================================================
# TLS Configuration (Optional)
# =============================================================================

# Path to TLS certificate file (enables HTTPS if set)
# LINE_PROXY_TLS_CERT=/path/to/cert.pem

# Path to TLS private key file
# LINE_PROXY_TLS_KEY=/path/to/key.pem
